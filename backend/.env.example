# LLM proxy
# auto: 本地默认推荐；有 LLM_PROXY_URL 时使用它，否则兼容 HTTP_PROXY/HTTPS_PROXY/ALL_PROXY
# off: 模型调用完全忽略系统代理，适合服务器全局代理会干扰模型服务时
# env: 强制使用系统代理环境变量
# url: 只使用 LLM_PROXY_URL
LLM_PROXY_MODE=auto
# LLM_PROXY_URL=socks5://127.0.0.1:7897

# mcp
MCP_API_KEY=MAK_XC_123456

EXTERNAL_API_KEYS=["xc-rpa-1ba531fa-264d-4fa2-b57c-006442b46f5d"]

# FineReport
FINEREPORT_PREVIEW_BASE_URL=http://192.168.14.41:1080
FR_AI_FINEREPORT_DB_NAME=XcTest

# FineReport AI SQL Server validation
FR_AI_SQLSERVER_ENABLED=false
FR_AI_SQLSERVER_HOST=192.168.14.113
FR_AI_SQLSERVER_PORT=1433
FR_AI_SQLSERVER_DATABASE=xctest
FR_AI_SQLSERVER_USER=sa
FR_AI_SQLSERVER_PASSWORD=change_me
FR_AI_SQLSERVER_ODBC_DRIVER=SQL Server
FR_AI_SQLSERVER_QUERY_TIMEOUT_SECONDS=10
FR_AI_SQLSERVER_MAX_ROWS=20

# SAP RFC
# Windows 需要把 SAP NetWeaver RFC SDK 的 lib 目录加入系统 PATH，例如：
# PATH=D:\sap\nwrfcsdk\lib;%PATH%
# Linux 需要配置 LD_LIBRARY_PATH=/opt/sap/nwrfcsdk/lib
SAPNWRFC_HOME=D:\sap\nwrfcsdk
SAP_NWRFC_LIB_DIR=D:\sap\nwrfcsdk\lib
SAP_DEV_800_USER=AI_RFC_USER
SAP_DEV_800_PASSWORD=change_me

