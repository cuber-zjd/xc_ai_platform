# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SERVER=192.168.14.44
POSTGRES_PORT=9500
POSTGRES_DB=ai_platform_test

# Redis
REDIS_HOST=192.168.14.44
REDIS_PORT=9501

# 平台通用 MinIO / S3 API，用于合同、知识库、图标等平台文件。
MINIO_ENDPOINT=192.168.14.44:9502
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET_NAME=ai-platform-files

# Milvus
MILVUS_HOST=192.168.14.44
MILVUS_PORT=9504

# LangFuse
LANGFUSE_PUBLIC_KEY=pk-lf-9ce120b1-ec19-47a1-b7e2-678ee36ddd62
LANGFUSE_SECRET_KEY=sk-lf-f274860a-ab3c-4fed-ab38-a18ef355247c
LANGFUSE_HOST=http://192.168.14.44:9506

# LLM proxy
# auto: 本地默认推荐；有 LLM_PROXY_URL 时使用它，否则兼容 HTTP_PROXY/HTTPS_PROXY/ALL_PROXY
# off: 模型调用完全忽略系统代理，适合服务器全局代理会干扰模型服务时
# env: 强制使用系统代理环境变量
# url: 只使用 LLM_PROXY_URL
LLM_PROXY_MODE=auto
# LLM_PROXY_URL=socks5://127.0.0.1:7897

# mcp
MCP_API_KEY=MAK_XC_123456

EXTERNAL_API_KEYS=["xc-rpa-1ba531fa-264d-4fa2-b57c-006442b46f5d"]

# FineReport
FINEREPORT_PREVIEW_BASE_URL=http://192.168.14.41:1080
FR_AI_FINEREPORT_DB_NAME=XcTest
# 帆软 MinIO / S3 API。控制台地址通常是 http://192.168.14.41:9006/minio，后端必须使用 S3 API 端口 9000。
FR_AI_MINIO_ENDPOINT=192.168.14.41:9000
FR_AI_MINIO_ACCESS_KEY=minioadmin
FR_AI_MINIO_SECRET_KEY=change_me
FR_AI_MINIO_BUCKET_NAME=fanruan
FR_AI_MINIO_SECURE=false
FR_AI_REPORT_FILE_PREFIXES=webroot/APP/reportlets
FR_AI_REPORT_FILE_EXTENSIONS=.cpt,.frm

# FineReport AI SQL Server validation
FR_AI_SQLSERVER_ENABLED=false
FR_AI_SQLSERVER_HOST=192.168.14.113
FR_AI_SQLSERVER_PORT=1433
FR_AI_SQLSERVER_DATABASE=xctest
FR_AI_SQLSERVER_USER=sa
FR_AI_SQLSERVER_PASSWORD=change_me
FR_AI_SQLSERVER_ODBC_DRIVER=SQL Server
FR_AI_SQLSERVER_QUERY_TIMEOUT_SECONDS=10
FR_AI_SQLSERVER_MAX_ROWS=20

# Insight crawler
INSIGHT_FIRECRAWL_BASE_URL=http://192.168.14.44:3002
INSIGHT_FIRECRAWL_API_KEY=
INSIGHT_FIRECRAWL_TIMEOUT_SECONDS=60
INSIGHT_BOCHA_API_KEY=
INSIGHT_BOCHA_BASE_URL=https://api.bocha.cn
INSIGHT_SEARCH_TIMEOUT_SECONDS=30
INSIGHT_SCHEDULER_ENABLED=false
INSIGHT_SCHEDULER_INTERVAL_SECONDS=300
INSIGHT_SCHEDULER_BATCH_LIMIT=5
INSIGHT_SCHEDULER_STARTUP_DELAY_SECONDS=15
INSIGHT_SCHEDULER_ADVISORY_LOCK_ID=2026060601
INSIGHT_SCHEDULER_USER_ID=1
INSIGHT_SCHEDULER_FAILURE_PAUSE_THRESHOLD=3

# Insight WeCom notification
INSIGHT_WECOM_SEND_ENABLED=false
INSIGHT_WECOM_CORP_ID=
INSIGHT_WECOM_AGENT_ID=
INSIGHT_WECOM_SECRET=
INSIGHT_WECOM_BASE_URL=https://qyapi.weixin.qq.com
INSIGHT_WECOM_TIMEOUT_SECONDS=10
INSIGHT_WECOM_RETRY_MAX_ATTEMPTS=3
# 用于企业微信卡片跳转，生产环境请填前端可访问地址，例如 http://192.168.14.44:5173
INSIGHT_PUBLIC_BASE_URL=

# SAP RFC
# Windows 需要把 SAP NetWeaver RFC SDK 的 lib 目录加入系统 PATH，例如：
# PATH=D:\sap\nwrfcsdk\lib;%PATH%
# Linux 需要配置 LD_LIBRARY_PATH=/opt/sap/nwrfcsdk/lib
SAPNWRFC_HOME=D:\sap\nwrfcsdk
SAP_NWRFC_LIB_DIR=D:\sap\nwrfcsdk\lib
SAP_DEV_800_USER=AI_RFC_USER
SAP_DEV_800_PASSWORD=change_me


